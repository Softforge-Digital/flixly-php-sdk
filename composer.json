{
  "name": "flixly/sdk",
  "description": "Official Flixly AI SDK for PHP. Generate images, video, audio, and chat completions through Flixly's public API.",
  "type": "library",
  "license": "MIT",
  "keywords": ["flixly", "ai", "image-generation", "video-generation", "wordpress"],
  "homepage": "https://www.flixly.ai/developers",
  "authors": [
    {
      "name": "Flixly",
      "email": "support@flixly.ai",
      "homepage": "https://www.flixly.ai"
    }
  ],
  "require": {
    "php": ">=7.4",
    "ext-json": "*",
    "ext-curl": "*",
    "ext-hash": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0 || ^10.0"
  },
  "autoload": {
    "psr-4": {
      "Flixly\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Flixly\\Tests\\": "tests/"
    }
  },
  "support": {
    "issues": "https://github.com/hmzlife/flixly-php-sdk/issues",
    "source": "https://github.com/hmzlife/flixly-php-sdk"
  }
}
